# Briefing delivery settings. Copy to briefing.conf and fill in what you use.
# briefing.conf is git-ignored. Choose Telegram, email, or both, and set
# preferences.brief_delivery in profile.yaml (auto picks whatever is configured).

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot with @BotFather, message it once, then get your chat id from
# https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Works headless from the 9am cron. For Gmail: host smtp.gmail.com, port 587,
# and an App Password (https://myaccount.google.com/apppasswords), NOT your login.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
# EMAIL_FROM=        # optional, defaults to SMTP_USER
